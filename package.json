{
  "name": "x402-header-agent",
  "version": "0.2.4",
  "description": "Simple Circle Gateway x402 header payment SDK for Arc buyer/seller agents, with DCW-only buyer signing and native Python adapters.",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    ".env.example",
    "python",
    "!python/**/__pycache__",
    "!python/**/*.pyc",
    "!python/**/*.pyo",
    "!python/**/*.egg-info",
    "!python/build",
    "!python/dist",
    "!python/.venv",
    "!python/**/.venv",
    "!python/.x402-ledger.json",
    "!python/.x402-ledger.json.lock",
    "!**/.x402-ledger.json",
    "!**/.x402-ledger.json.lock"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 tests/*.test.ts",
    "example:buyer": "tsx --env-file=.env examples/buyer-agent.ts",
    "example:seller": "tsx --env-file=.env examples/seller-express.ts",
    "example:batch": "tsx --env-file=.env examples/batch-buyer.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.7.1",
    "@circle-fin/x402-batching": "^3.2.0",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "viem": "^2.53.1",
    "zod": "^3.25.0",
    "express": "^4.18.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
