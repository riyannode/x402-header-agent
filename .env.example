# Circle Developer-Controlled Wallet buyer. No raw buyer private key is used by this SDK.
CIRCLE_API_KEY=TEST_API_KEY:ID:SECRET
CIRCLE_ENTITY_SECRET=your_64_char_hex_entity_secret_from_secret_manager
CIRCLE_DCW_WALLET_ID=00000000-0000-0000-0000-000000000000
CIRCLE_DCW_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
CIRCLE_DCW_BLOCKCHAIN=ARC-TESTNET

# Seller receives funds here. This can also be a Circle DCW EOA address.
SELLER_ADDRESS=0x0000000000000000000000000000000000000000

# Arc/Circle Gateway defaults.
X402_CHAIN=arcTestnet
X402_NETWORK=eip155:5042002
X402_FACILITATOR_URL=https://gateway-api-testnet.circle.com
X402_DEFAULT_PRICE_USDC=0.001
ARC_RPC_URL=https://rpc.testnet.arc.network

# Buyer policy.
X402_DAILY_BUDGET_USDC=10
X402_MAX_SINGLE_PAYMENT_USDC=1
X402_MAX_BATCH_PAYMENT_USDC=5
X402_HOST_ALLOWLIST=seller.example.com
X402_ALLOW_LOCALHOST=false
X402_LEDGER_PATH=.x402-ledger.json

# Local demo only:
# X402_HOST_ALLOWLIST=localhost,127.0.0.1
# X402_ALLOW_LOCALHOST=true
